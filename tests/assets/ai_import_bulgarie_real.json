     "fr": "Dépôt du dossier initial",
     "en": "Initial file submission",
     "es": "Presentación del expediente inicial",
     "pt": "Envio do dossiê inicial",
     "ru": "Подача первоначального досье"
    },
    "delai_jours": 5,
    "validee_par": "agence",
    "participants": [
     {
      "acteur": "client",
      "role": "fournit_documents"
     },
     {
      "acteur": "agence",
      "role": "executant"
     }
    ],
    "prerequis": [],
    "informations_a_collecter": [
     {
      "cle": "nationalite",
      "type": "country",
      "requis": true,
      "libelle": {
       "fr": "Nationalité",
       "en": "Nationality"
      }
     },
     {
      "cle": "adresse_actuelle",
      "type": "address",
      "requis": true,
      "libelle": {
       "fr": "Adresse de résidence actuelle",
       "en": "Current residential address"
      }
     },
     {
      "cle": "pays_residence_fiscale",
      "type": "country",
      "requis": true,
      "libelle": {
       "fr": "Pays de résidence fiscale actuel",
       "en": "Current country of tax residence"
      }
     }
