{
 "version": 1,
 "parcours": {
  "nom": {
   "fr": "Création de société en Bulgarie",
   "en": "Company setup in Bulgaria",
   "es": "Creación de sociedad en Bulgaria",
   "pt": "Criação de empresa na Bulgária",
   "ru": "Регистрация компании в Болгарии"
