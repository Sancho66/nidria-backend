    "validee_par": "agence",
    "participants": [
     {
      "acteur": "agence",
      "role": "executant"
     },
     {
      "acteur": "client",
      "role": "contributeur"
     }
    ],
    "prerequis": [
     "depot_dossier"
    ],
    "informations_a_collecter": [
     {
      "cle": "nom_societe_1",
      "type": "text",
      "requis": true,
      "libelle": {
       "fr": "Nom de société souhaité (1er choix)",
       "en": "Preferred company name (1st choice)"
      }
     },
     {
      "cle": "nom_societe_2",
      "type": "text",
      "requis": false,
      "libelle": {
       "fr": "Nom de société alternatif (2e choix)",
       "en": "Alternative company name (2nd choice)"
      }
     },
     {
      "cle": "activite_principale",
      "type": "text",
      "requis": true,
      "libelle": {
       "fr": "Description de l'activité principale",
       "en": "Description of the main business activity"
      }
     }
    ],
    "informations_fournies": {
     "note": {
      "fr": "Nous vérifions la disponibilité du nom auprès du Registre du commerce bulgare. Prévoyez une alternative en cas d'indisponibilité.",
      "en": "We check the name's availability with the Bulgarian Commercial Register. Please provide an alternative in case it is unavailable."
     }
    }
   },
   {
    "ref": "siege_social",
    "nom": {
     "fr": "Choix du siège social",
     "en": "Registered office selection",
     "es": "Elección del domicilio social",
     "pt": "Escolha da sede social",
     "ru": "Выбор юридического адреса"
