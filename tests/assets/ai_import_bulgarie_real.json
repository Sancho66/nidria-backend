      "options": [
       {
        "valeur": "banque_traditionnelle",
        "libelle": {
         "fr": "Banque traditionnelle bulgare (présence requise)",
         "en": "Traditional Bulgarian bank (in-person visit required)"
        }
       },
       {
        "valeur": "fintech",
        "libelle": {
         "fr": "Établissement de paiement en ligne",
         "en": "Online payment institution"
        }
       },
       {
        "valeur": "les_deux",
        "libelle": {
         "fr": "Les deux",
         "en": "Both"
        }
       }
      ]
     },
     {
      "cle": "devises",
      "type": "select_multi",
      "requis": false,
      "libelle": {
       "fr": "Devises souhaitées sur le compte",
       "en": "Desired account currencies"
      },
      "options": [
       {
        "valeur": "eur",
        "libelle": {
         "fr": "Euro (EUR)",
         "en": "Euro (EUR)"
        }
       },
       {
        "valeur": "usd",
        "libelle": {
         "fr": "Dollar américain (USD)",
         "en": "US dollar (USD)"
        }
       },
       {
        "valeur": "gbp",
        "libelle": {
         "fr": "Livre sterling (GBP)",
         "en": "Pound sterling (GBP)"
        }
       },
       {
        "valeur": "autre",
        "libelle": {
         "fr": "Autres devises",
         "en": "Other currencies"
        }
       }
      ]
     }
    ],
    "informations_fournies": {
     "note": {
      "fr": "La plupart des banques bulgares exigent la présence du gérant (contrôle KYC). Le compte de capital est transformé en compte courant ou un compte opérationnel distinct est ouvert.",
      "en": "Most Bulgarian banks require the manager to be present (KYC check). The capital account is converted into a current account or a separate operational account is opened."
     }
    }
   },
   {
    "ref": "comptabilite",
    "nom": {
     "fr": "Mise en place de la comptabilité",
     "en": "Accounting setup",
     "es": "Puesta en marcha de la contabilidad",
     "pt": "Implementação da contabilidade",
     "ru": "Организация бухгалтерского учёта"
    },
    "delai_jours": 5,
    "validee_par": "agence",
    "participants": [
     {
      "acteur": "prestataire:comptable",
      "role": "executant"
     },
     {
      "acteur": "client",
      "role": "contributeur"
     },
     {
      "acteur": "agence",
      "role": "contributeur"
     }
    ],
    "prerequis": [
     "immatriculation"
    ],
    "informations_a_collecter": [
     {
      "cle": "volume_factures",
      "type": "number",
      "requis": false,
      "libelle": {
       "fr": "Nombre estimé de factures par mois",
       "en": "Estimated number of invoices per month"
      }
     },
     {
      "cle": "salaries_prevus",
      "type": "boolean",
      "requis": true,
      "libelle": {
       "fr": "Prévoyez-vous des embauches la première année ?",
       "en": "Do you plan to hire employees in the first year?"
      }
     }
    ],
    "informations_fournies": {
     "note": {
      "fr": "Mise en place de la comptabilité mensuelle et du calendrier des obligations : TVA, impôt sur les sociétés (taux fixe de 10 %), déclarations annuelles.",
      "en": "Setup of monthly bookkeeping and the compliance calendar: VAT, corporate income tax (10% flat rate), annual filings."
     }
    }
   },
   {
    "ref": "remise_dossier",
    "nom": {
     "fr": "Remise du dossier final",
     "en": "Final handover",
     "es": "Entrega del expediente final",
     "pt": "Entrega do dossiê final",
     "ru": "Передача итогового досье"
    },
    "delai_jours": 3,
    "validee_par": "agence",
    "participants": [
     {
      "acteur": "agence",
      "role": "executant"
     },
     {
      "acteur": "client",
      "role": "informe"
     }
    ],
    "prerequis": [
     "enregistrement_tva",
     "compte_bancaire",
     "comptabilite"
    ],
    "informations_a_collecter": [
     {
      "cle": "services_complementaires",
      "type": "select_multi",
      "requis": false,
      "libelle": {
       "fr": "Services complémentaires souhaités",
       "en": "Additional services of interest"
      },
      "options": [
       {
        "valeur": "residence",
        "libelle": {
         "fr": "Demande de titre de séjour en Bulgarie",
         "en": "Bulgarian residence permit application"
        }
       },
       {
        "valeur": "compte_personnel",
        "libelle": {
         "fr": "Ouverture d'un compte bancaire personnel",
         "en": "Personal bank account opening"
        }
       },
       {
        "valeur": "fiscalite_depart",
        "libelle": {
         "fr": "Formalités fiscales dans le pays de départ",
         "en": "Tax formalities in the departure country"
