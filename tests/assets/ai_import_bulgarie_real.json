    "informations_a_collecter": [
     {
      "cle": "tva_volontaire",
      "type": "boolean",
      "requis": true,
      "libelle": {
       "fr": "Souhaitez-vous une immatriculation TVA volontaire dès la création ?",
       "en": "Do you want voluntary VAT registration from incorporation?"
      }
     },
     {
      "cle": "clients_ue",
      "type": "boolean",
      "requis": true,
      "libelle": {
       "fr": "Facturerez-vous des clients établis dans l'Union européenne ?",
       "en": "Will you invoice clients established in the European Union?"
      }
     }
    ],
    "informations_fournies": {
     "note": {
      "fr": "L'immatriculation TVA devient obligatoire au-delà du seuil légal de chiffre d'affaires ; une immatriculation volontaire immédiate est souvent recommandée pour une activité B2B intra-UE. L'administration statue sous 14 jours.",
      "en": "VAT registration becomes mandatory above the legal turnover threshold; immediate voluntary registration is often recommended for intra-EU B2B activity. The tax authority decides within 14 days."
     }
    }
   },
   {
    "ref": "compte_bancaire",
    "nom": {
     "fr": "Ouverture du compte bancaire professionnel",
     "en": "Business bank account opening",
     "es": "Apertura de la cuenta bancaria profesional",
     "pt": "Abertura da conta bancária empresarial",
     "ru": "Открытие корпоративного банковского счёта"
