       },
       {
        "valeur": "adresse_propre",
        "libelle": {
         "fr": "Je dispose déjà d'une adresse en Bulgarie",
         "en": "I already have an address in Bulgaria"
        }
       },
       {
        "valeur": "bureau",
        "libelle": {
         "fr": "Location d'un bureau physique",
         "en": "Physical office rental"
        }
       }
      ]
     },
     {
      "cle": "ville_siege",
      "type": "select_single",
      "requis": true,
      "libelle": {
       "fr": "Ville du siège social",
       "en": "City of the registered office"
      },
      "options": [
       {
        "valeur": "sofia",
        "libelle": {
         "fr": "Sofia",
         "en": "Sofia"
        }
       },
       {
        "valeur": "plovdiv",
        "libelle": {
         "fr": "Plovdiv",
         "en": "Plovdiv"
        }
       },
       {
        "valeur": "varna",
        "libelle": {
         "fr": "Varna",
         "en": "Varna"
        }
       },
       {
        "valeur": "burgas",
        "libelle": {
         "fr": "Bourgas",
         "en": "Burgas"
        }
       },
       {
        "valeur": "autre",
        "libelle": {
         "fr": "Autre ville",
         "en": "Other city"
        }
       }
      ]
     }
    ],
    "informations_fournies": {
     "note": {
      "fr": "Toute société bulgare doit disposer d'un siège social en Bulgarie, mentionné dans les statuts. Notre service de domiciliation inclut la réception et la numérisation du courrier officiel.",
      "en": "Every Bulgarian company must have a registered office in Bulgaria, stated in the articles of association. Our registered address service includes receiving and scanning official mail."
     }
    }
   },
   {
    "ref": "preparation_actes",
    "nom": {
     "fr": "Préparation des actes constitutifs",
     "en": "Drafting of incorporation documents",
     "es": "Preparación de los documentos constitutivos",
     "pt": "Preparação dos documentos de constituição",
     "ru": "Подготовка учредительных документов"
    },
    "delai_jours": 5,
    "validee_par": "personne",
    "participants": [
     {
      "acteur": "prestataire:avocat",
      "role": "executant"
     },
     {
      "acteur": "agence",
      "role": "contributeur"
     },
     {
      "acteur": "client",
      "role": "informe"
     }
    ],
    "prerequis": [
     "verification_nom",
     "siege_social"
    ],
    "informations_a_collecter": [
     {
      "cle": "type_societe",
      "type": "select_single",
      "requis": true,
      "libelle": {
       "fr": "Forme juridique souhaitée",
       "en": "Desired legal form"
      },
      "options": [
       {
        "valeur": "eood",
        "libelle": {
         "fr": "EOOD — SARL unipersonnelle (associé unique)",
         "en": "EOOD — single-member limited liability company"
        }
       },
       {
        "valeur": "ood",
        "libelle": {
         "fr": "OOD — SARL à plusieurs associés",
         "en": "OOD — multi-member limited liability company"
        }
       }
      ]
     },
     {
      "cle": "capital_social",
      "type": "number",
      "requis": true,
      "libelle": {
       "fr": "Capital social souhaité (en euros)",
       "en": "Desired share capital (in euros)"
      }
     },
     {
      "cle": "nb_associes",
      "type": "number",
      "requis": false,
      "libelle": {
       "fr": "Nombre d'associés (si OOD)",
       "en": "Number of shareholders (if OOD)"
      }
     }
