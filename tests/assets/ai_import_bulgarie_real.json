    "informations_fournies": {
     "note": {
      "fr": "Notre avocat partenaire rédige les statuts, l'acte de constitution et le consentement du gérant. Le capital minimum légal est symbolique ; un montant plus élevé renforce la crédibilité bancaire.",
      "en": "Our partner lawyer drafts the articles of association, the incorporation deed and the manager's consent. The legal minimum capital is symbolic; a higher amount strengthens banking credibility."
     }
    }
   },
   {
    "ref": "notarisation",
    "nom": {
     "fr": "Signature et légalisation notariale",
     "en": "Signature and notarization",
     "es": "Firma y legalización notarial",
     "pt": "Assinatura e reconhecimento notarial",
     "ru": "Подписание и нотариальное заверение"
    },
    "delai_jours": 7,
    "validee_par": "agence",
    "participants": [
     {
      "acteur": "client",
      "role": "executant"
     },
     {
      "acteur": "prestataire:notaire",
      "role": "executant"
     },
     {
      "acteur": "agence",
      "role": "contributeur"
     }
    ],
    "prerequis": [
     "preparation_actes"
    ],
    "informations_a_collecter": [
     {
      "cle": "deplacement_bulgarie",
      "type": "boolean",
      "requis": true,
      "libelle": {
       "fr": "Pouvez-vous vous déplacer en Bulgarie pour la signature ?",
       "en": "Can you travel to Bulgaria for the signing?"
      }
     }
    ],
    "informations_fournies": {
     "note": {
      "fr": "Le spécimen de signature du gérant doit être certifié : devant notaire en Bulgarie, ou à distance via une procuration notariée munie d'une apostille dans votre pays de résidence.",
      "en": "The manager's specimen signature must be certified: before a notary in Bulgaria, or remotely via a notarized power of attorney with an apostille in your country of residence."
     }
    }
   },
   {
    "ref": "traduction_documents",
    "nom": {
     "fr": "Traduction certifiée en bulgare",
     "en": "Certified translation into Bulgarian",
     "es": "Traducción jurada al búlgaro",
     "pt": "Tradução juramentada para o búlgaro",
     "ru": "Заверенный перевод на болгарский язык"
    },
    "delai_jours": 7,
    "validee_par": "personne",
    "participants": [
     {
      "acteur": "prestataire:traducteur",
      "role": "executant"
     },
     {
      "acteur": "agence",
      "role": "contributeur"
     },
     {
      "acteur": "client",
      "role": "informe"
     }
    ],
    "prerequis": [
     "notarisation"
    ],
    "informations_a_collecter": [],
    "informations_fournies": {
     "note": {
      "fr": "Traduction certifiée en bulgare des documents établis à l'étranger (procuration apostillée, pièces d'identité) par un traducteur assermenté. Le dossier traduit sera déposé ici.",
      "en": "Certified translation into Bulgarian of documents issued abroad (apostilled power of attorney, identity documents) by a sworn translator. The translated file will be uploaded here."
     }
    }
   },
   {
    "ref": "depot_capital",
    "nom": {
     "fr": "Dépôt du capital social",
     "en": "Share capital deposit",
     "es": "Depósito del capital social",
     "pt": "Depósito do capital social",
     "ru": "Внесение уставного капитала"
    },
    "delai_jours": 5,
    "validee_par": "agence",
    "participants": [
     {
      "acteur": "client",
      "role": "executant"
     },
     {
      "acteur": "prestataire:banque",
      "role": "contributeur"
     },
     {
      "acteur": "agence",
      "role": "contributeur"
     }
    ],
    "prerequis": [
     "notarisation"
    ],
    "informations_a_collecter": [],
    "informations_fournies": {
     "note": {
      "fr": "Ouverture du compte de capital et versement du capital social. L'attestation de dépôt délivrée par la banque est indispensable à l'immatriculation.",
      "en": "Opening of the capital account and payment of the share capital. The deposit certificate issued by the bank is required for registration."
     }
    }
   },
   {
    "ref": "immatriculation",
    "nom": {
     "fr": "Immatriculation au Registre du commerce",
     "en": "Registration with the Commercial Register",
     "es": "Inscripción en el Registro Mercantil",
     "pt": "Registro no Registro Comercial",
     "ru": "Регистрация в Торговом реестре"
    },
    "delai_jours": 5,
    "validee_par": "personne",
    "participants": [
     {
      "acteur": "prestataire:avocat",
      "role": "executant"
     },
     {
      "acteur": "agence",
      "role": "contributeur"
     },
     {
      "acteur": "client",
      "role": "informe"
     }
    ],
    "prerequis": [
     "traduction_documents",
     "depot_capital"
    ],
    "informations_a_collecter": [],
    "informations_fournies": {
     "note": {
      "fr": "Dépôt du dossier complet au Registre du commerce. Votre société reçoit son numéro d'identification unique (EIK), généralement sous 3 à 5 jours ouvrés.",
      "en": "Filing of the complete file with the Commercial Register. Your company receives its unique identification number (EIK), usually within 3 to 5 business days."
     }
    }
   },
   {
    "ref": "enregistrement_tva",
    "nom": {
     "fr": "Immatriculation à la TVA",
     "en": "VAT registration",
     "es": "Alta en el IVA",
     "pt": "Registro de IVA",
     "ru": "Регистрация плательщиком НДС"
    },
    "delai_jours": 14,
    "validee_par": "personne",
    "participants": [
     {
      "acteur": "prestataire:comptable",
      "role": "executant"
     },
     {
      "acteur": "client",
      "role": "informe"
     }
    ],
    "prerequis": [
     "immatriculation"
