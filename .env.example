# --- Database --------------------------------------------------------------
# Local dev: dockerized PostgreSQL 16 (docker-compose.dev.yml, host port 5435).
# Production: Supabase connection strings.
# Async driver (asyncpg) used by the API.
DATABASE_URL=postgresql+asyncpg://nidria:nidria@localhost:5435/nidria
# Sync driver (psycopg2) used by Alembic migrations and the scheduler.
DATABASE_URL_SYNC=postgresql+psycopg2://nidria:nidria@localhost:5435/nidria

# --- Auth (JWT) ------------------------------------------------------------
# Two access audiences (agent / expat), each with its own secret, plus a
# single refresh secret (the refresh token carries an `audience` claim).
JWT_AGENT_SECRET=
JWT_EXPAT_SECRET=
JWT_REFRESH_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_DAYS=7

# --- Scheduler (reminder dispatch) ------------------------------------------
SCHEDULER_ENABLED=false

# --- Mocks -----------------------------------------------------------------
# Global toggle (default true for safety). All external services return
# realistic mock data unless overridden per-service below.
MOCK_SERVICES=true
# Per-service override. Unset by default → uses MOCK_SERVICES.
# MOCK_EMAIL=false   # send real invitations + mail reminders via Resend

# --- API -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=Nidria <notifications@nidria.com>

# --- Supabase Storage (documents) -------------------------------------------
# SERVICE ROLE key (Settings → API → service_role), NOT the anon key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents
